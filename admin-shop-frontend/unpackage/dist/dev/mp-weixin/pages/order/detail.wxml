<view class="order-detail data-v-57d42baa"><view class="{{['status-section','data-v-57d42baa','status-bg-'+order.status]}}"><text class="status-section__text data-v-57d42baa">{{$root.m0}}</text><text class="status-section__desc data-v-57d42baa">{{$root.m1}}</text></view><block wx:if="{{addressInfo}}"><view class="address-section data-v-57d42baa"><view class="address-section__icon data-v-57d42baa"><text class="data-v-57d42baa">📍</text></view><view class="address-section__info data-v-57d42baa"><view class="address-section__user data-v-57d42baa"><text class="address-section__name data-v-57d42baa">{{addressInfo.receiverName}}</text><text class="address-section__phone data-v-57d42baa">{{addressInfo.phone}}</text></view><text class="address-section__detail data-v-57d42baa">{{addressInfo.province+addressInfo.city+addressInfo.district+addressInfo.detail}}</text></view></view></block><view class="goods-section data-v-57d42baa"><view class="section-title data-v-57d42baa"><text class="data-v-57d42baa">商品信息</text></view><block wx:for="{{order.items}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="goods-item data-v-57d42baa"><image class="goods-item__image data-v-57d42baa" src="{{item.image}}" mode="aspectFill"></image><view class="goods-item__info data-v-57d42baa"><text class="goods-item__name data-v-57d42baa">{{item.productName}}</text><block wx:if="{{item.skuSpecDesc}}"><text class="goods-item__spec data-v-57d42baa">{{item.skuSpecDesc}}</text></block><view class="goods-item__bottom data-v-57d42baa"><text class="goods-item__price data-v-57d42baa">{{"¥"+item.price}}</text><text class="goods-item__qty data-v-57d42baa">{{"x"+item.quantity}}</text></view></view></view></block></view><view class="amount-section data-v-57d42baa"><view class="section-title data-v-57d42baa"><text class="data-v-57d42baa">金额信息</text></view><view class="amount-row data-v-57d42baa"><text class="amount-row__label data-v-57d42baa">商品总额</text><text class="amount-row__value data-v-57d42baa">{{"¥"+order.totalAmount}}</text></view><view class="amount-row data-v-57d42baa"><text class="amount-row__label data-v-57d42baa">运费</text><text class="amount-row__value data-v-57d42baa">免运费</text></view><view class="amount-row amount-row--total data-v-57d42baa"><text class="amount-row__label data-v-57d42baa">实付金额</text><text class="amount-row__value amount-row__value--price data-v-57d42baa">{{"¥"+order.totalAmount}}</text></view></view><view class="info-section data-v-57d42baa"><view class="section-title data-v-57d42baa"><text class="data-v-57d42baa">订单信息</text></view><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">订单编号</text><text class="info-row__value data-v-57d42baa">{{order.orderNo}}</text></view><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">创建时间</text><text class="info-row__value data-v-57d42baa">{{order.createTime}}</text></view><block wx:if="{{order.paymentTime}}"><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">支付时间</text><text class="info-row__value data-v-57d42baa">{{order.paymentTime}}</text></view></block><block wx:if="{{order.shippingTime}}"><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">发货时间</text><text class="info-row__value data-v-57d42baa">{{order.shippingTime}}</text></view></block><block wx:if="{{order.completeTime}}"><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">完成时间</text><text class="info-row__value data-v-57d42baa">{{order.completeTime}}</text></view></block><block wx:if="{{order.cancelTime}}"><view class="info-row data-v-57d42baa"><text class="info-row__label data-v-57d42baa">取消时间</text><text class="info-row__value data-v-57d42baa">{{order.cancelTime}}</text></view></block></view><block wx:if="{{order.status===0}}"><view class="bottom-placeholder data-v-57d42baa"></view></block><block wx:if="{{order.status===0}}"><view class="bottom-bar data-v-57d42baa"><view data-event-opts="{{[['tap',[['handleCancel',['$event']]]]]}}" class="bottom-bar__btn bottom-bar__btn--cancel data-v-57d42baa" bindtap="__e"><text class="bottom-bar__btn-text data-v-57d42baa">取消订单</text></view><view data-event-opts="{{[['tap',[['handlePay',['$event']]]]]}}" class="bottom-bar__btn bottom-bar__btn--pay data-v-57d42baa" bindtap="__e"><text class="bottom-bar__btn-text bottom-bar__btn-text--white data-v-57d42baa">立即支付</text></view></view></block></view>