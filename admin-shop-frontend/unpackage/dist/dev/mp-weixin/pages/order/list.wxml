<view class="order-list data-v-6546c710"><view class="tabs data-v-6546c710"><block wx:for="{{tabs}}" wx:for-item="tab" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['switchTab',[index]]]]]}}" class="{{['tabs__item','data-v-6546c710',(currentTab===index)?'tabs__item--active':'']}}" bindtap="__e"><text class="tabs__text data-v-6546c710">{{tab.name}}</text><block wx:if="{{currentTab===index}}"><view class="tabs__line data-v-6546c710"></view></block></view></block></view><view class="list-content data-v-6546c710"><block wx:if="{{$root.g0===0}}"><view class="empty data-v-6546c710"><text class="empty__text data-v-6546c710">暂无订单</text></view></block><block wx:for="{{$root.l0}}" wx:for-item="order" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['goDetail',['$0'],[[['orderList','id',order.$orig.id,'id']]]]]]]}}" class="order-card data-v-6546c710" bindtap="__e"><view class="order-card__header data-v-6546c710"><text class="order-card__no data-v-6546c710">{{"订单号："+order.$orig.orderNo}}</text><text class="{{['order-card__status','data-v-6546c710','status-'+order.$orig.status]}}">{{order.m0}}</text></view><view class="order-card__goods data-v-6546c710"><block wx:for="{{order.$orig.items}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><view class="order-card__goods-item data-v-6546c710"><image class="order-card__goods-image data-v-6546c710" src="{{item.image}}" mode="aspectFill"></image><view class="order-card__goods-info data-v-6546c710"><text class="order-card__goods-name data-v-6546c710">{{item.productName}}</text><block wx:if="{{item.skuSpecDesc}}"><text class="order-card__goods-spec data-v-6546c710">{{item.skuSpecDesc}}</text></block><view class="order-card__goods-bottom data-v-6546c710"><text class="order-card__goods-price data-v-6546c710">{{"¥"+item.price}}</text><text class="order-card__goods-qty data-v-6546c710">{{"x"+item.quantity}}</text></view></view></view></block></view><view class="order-card__footer data-v-6546