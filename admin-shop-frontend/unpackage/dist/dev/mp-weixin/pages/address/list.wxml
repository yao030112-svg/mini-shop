<view class="address-list data-v-5d053e52"><block wx:if="{{$root.g0>0}}"><view class="list-content data-v-5d053e52"><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['handleSelect',['$0'],[[['addressList','id',item.id]]]]]]]}}" class="address-card data-v-5d053e52" bindtap="__e"><view class="address-card__content data-v-5d053e52"><view class="address-card__top data-v-5d053e52"><text class="address-card__name data-v-5d053e52">{{item.receiverName}}</text><text class="address-card__phone data-v-5d053e52">{{item.phone}}</text><block wx:if="{{item.isDefault}}"><view class="address-card__tag data-v-5d053e52"><text class="address-card__tag-text data-v-5d053e52">默认</text></view></block></view><view class="address-card__detail data-v-5d053e52"><text class="address-card__detail-text data-v-5d053e52">{{item.province+item.city+item.district+item.detail}}</text></view></view><view class="address-card__actions data-v-5d053e52"><block wx:if="{{!item.isDefault}}"><view data-event-opts="{{[['tap',[['handleSetDefault',['$0'],[[['addressList','id',item.id,'id']]]]]]]}}" class="address-card__action data-v-5d053e52" catchtap="__e"><text class="address-card__action-text data-v-5d053e52">设为默认</text></view></block><view data-event-opts="{{[['tap',[['handleEdit',['$0'],[[['addressList','id',item.id,'id']]]]]]]}}" class="address-card__action data-v-5d053e52" catchtap="__e"><text class="address-card__action-text data-v-5d053e52">编辑</text></view><view data-event-opts="{{[['tap',[['handleDelete',['$0'],[[['addressList','id',item.id,'id']]]]]]]}}" class="address-card__action address-card__action--danger data-v-5d053e52" catchtap="__e"><text class="address-card__action-text address-card__action-text--danger data-v-5d053e52">删除</text></view></view></view></block></view></block><block wx:else><view class="empty data-v-5d053e52"><text class="empty__text data-v-5d053e52">暂无收货地址</text><text class="empty__sub data-v-5d053e52">点击下方按钮添加地址</text></view></block><view class="bottom-bar data-v-5d053e52"><view data-event-opts="{{[['tap',[['handleAdd',['$event']]]]]}}" class="add-btn data-v-5d053e52" bindtap="__e"><text class="add-btn__text data-v-5d053e52">新增地址</text></view></view></view>