<view class="address-edit data-v-6c4d65be"><view class="form data-v-6c4d65be"><view class="form-item data-v-6c4d65be"><text class="form-item__label data-v-6c4d65be">收货人</text><input class="form-item__input data-v-6c4d65be" placeholder="请输入收货人姓名" maxlength="20" data-event-opts="{{[['input',[['__set_model',['$0','receiverName','$event',[]],['form']]]]]}}" value="{{form.receiverName}}" bindinput="__e"/></view><view class="form-item data-v-6c4d65be"><text class="form-item__label data-v-6c4d65be">联系电话</text><input class="form-item__input data-v-6c4d65be" type="number" placeholder="请输入联系电话" maxlength="11" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['form']]]]]}}" value="{{form.phone}}" bindinput="__e"/></view><picker mode="region" value="{{regionValue}}" data-event-opts="{{[['change',[['onRegionChange',['$event']]]]]}}" bindchange="__e" class="data-v-6c4d65be"><view class="form-item data-v-6c4d65be"><text class="form-item__label data-v-6c4d65be">所在地区</text><view class="form-item__picker data-v-6c4d65be"><text class="{{['data-v-6c4d65be','form-item__picker-text',[(!regionText)?'form-item__picker-text--placeholder':'']]}}">{{''+(regionText||'请选择省市区')+''}}</text><text class="form-item__arrow data-v-6c4d65be">></text></view></view></picker><view class="form-item data-v-6c4d65be"><text class="form-item__label data-v-6c4d65be">详细地址</text><input class="form-item__input data-v-6c4d65be" placeholder="请输入详细地址（街道、门牌号等）" maxlength="100" data-event-opts="{{[['input',[['__set_model',['$0','detail','$event',[]],['form']]]]]}}" value="{{form.detail}}" bindinput="__e"/></view><view class="form-item form-item--switch data-v-6c4d65be"><text class="form-item__label data-v-6c4d65be">设为默认地址</text><switch checked="{{form.isDefault}}" color="#ff6600" data-event-opts="{{[['change',[['onSwitchChange',['$event']]]]]}}" bindchange="__e" class="data-v-6c4d65be"></switch></view></view><view class="save-section data-v-6c4d65be"><view data-event-opts="{{[['tap',[['handleSave