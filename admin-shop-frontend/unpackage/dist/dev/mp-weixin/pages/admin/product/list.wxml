<view class="admin-product data-v-e6f25c92"><view class="page-header data-v-e6f25c92"><text class="page-title data-v-e6f25c92">商品管理</text></view><view class="search-bar data-v-e6f25c92"><input class="search-input data-v-e6f25c92" placeholder="搜索商品名称" placeholder-class="placeholder" data-event-opts="{{[['confirm',[['loadProducts',['$event']]]],['input',[['__set_model',['','keyword','$event',[]]]]]]}}" value="{{keyword}}" bindconfirm="__e" bindinput="__e"/><button data-event-opts="{{[['tap',[['loadProducts',['$event']]]]]}}" class="search-btn data-v-e6f25c92" bindtap="__e">搜索</button></view><view class="product-list data-v-e6f25c92"><block wx:for="{{productList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="product-card data-v-e6f25c92"><image class="product-image data-v-e6f25c92" src="{{item.mainImage}}" mode="aspectFill"></image><view class="product-info data-v-e6f25c92"><text class="product-name data-v-e6f25c92">{{item.name}}</text><text class="product-price data-v-e6f25c92">{{"¥"+item.minPrice}}</text><view class="product-status data-v-e6f25c92"><text class="{{['data-v-e6f25c92','status-tag',item.status===1?'on':'off']}}">{{''+(item.status===1?'上架中':'已下架')+''}}</text></view></view><view class="product-actions data-v-e6f25c92"><switch checked="{{item.status===1}}" color="#ff6600" data-event-opts="{{[['change',[['handleStatusChange',['$0','$event'],[[['productList','id',item.id]]]]]]]}}" bindchange="__e" class="data-v-e6f25c92"></switch><button data-event-opts="{{[['tap',[['handleDelete',['$0'],[[['productList','id',item.id]]]]]]]}}" class="delete-btn data-v-e6f25c92" bindtap="__e">删除</button></view></view></block><block wx:if="{{$root.g0}}"><view class="empty data-v-e6f25c92"><text class="data-v-e6f25c92">暂无商品</text></view></block></view><block wx:if="{{$root.g1>0}}"><view class="pagination data-v-e6f25c92"><button class="page-btn data-v-e6f25c92" disabled="{{page<=1}}" data-event-opts="{{[['tap',[['prevPage',['$event']]]]]}}" bindtap="__e">上一页</button><text class="page-info data-v-e6f25c92">{{"第 "+page+" 页"}}</text><button class="page-btn data-v-e6f25c92" disabled="{{$root.g2<pageSize}}" data-event-opts="{{[['tap',[['nextPage',['$event']]]]]}}" bindtap="__e">下一页</button></view></block><view class="admin-nav data-v-e6f25c92"><view class="nav-item active data-v-e6f25c92"><text class="data-v-e6f25c92">商品</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/category/list']]]]]}}" class="nav-item data-v-e6f25c92" bindtap="__e"><text class="data-v-e6f25c92">分类</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/order/list']]]]]}}" class="nav-item data-v-e6f25c92" bindtap="__e"><text class="data-v-e6f25c92">订单</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/user/list']]]]]}}" class="nav-item data-v-e6f25c92" bindtap="__e"><text class="data-v-e6f25c92">用户</text></view></view></view>