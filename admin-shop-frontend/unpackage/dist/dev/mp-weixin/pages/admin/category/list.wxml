<view class="admin-category data-v-2d2095e6"><view class="page-header data-v-2d2095e6"><text class="page-title data-v-2d2095e6">分类管理</text><button data-event-opts="{{[['tap',[['showAddDialog',['$event']]]]]}}" class="add-btn data-v-2d2095e6" bindtap="__e">添加分类</button></view><view class="category-list data-v-2d2095e6"><block wx:for="{{categoryList}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="category-item data-v-2d2095e6"><view class="category-info data-v-2d2095e6"><text class="category-name data-v-2d2095e6">{{item.name}}</text><text class="category-sort data-v-2d2095e6">{{"排序: "+(item.sortOrder||0)}}</text></view><view class="category-actions data-v-2d2095e6"><button data-event-opts="{{[['tap',[['handleSortUp',['$0',index],[[['categoryList','id',item.id]]]]]]]}}" class="action-btn sort-btn data-v-2d2095e6" bindtap="__e">↑</button><button data-event-opts="{{[['tap',[['handleSortDown',['$0',index],[[['categoryList','id',item.id]]]]]]]}}" class="action-btn sort-btn data-v-2d2095e6" bindtap="__e">↓</button><button data-event-opts="{{[['tap',[['showEditDialog',['$0'],[[['categoryList','id',item.id]]]]]]]}}" class="action-btn edit-btn data-v-2d2095e6" bindtap="__e">编辑</button><button data-event-opts="{{[['tap',[['handleDelete',['$0'],[[['categoryList','id',item.id]]]]]]]}}" class="action-btn del-btn data-v-2d2095e6" bindtap="__e">删除</button></view></view></block><block wx:if="{{$root.g0}}"><view class="empty data-v-2d2095e6"><text class="data-v-2d2095e6">暂无分类</text></view></block></view><block wx:if="{{dialogVisible}}"><view data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="dialog-mask data-v-2d2095e6" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="dialog data-v-2d2095e6" catchtap="__e"><text class="dialog-title data-v-2d2095e6">{{isEdit?'编辑分类':'添加分类'}}</text><view class="dialog-body data-v-2d2095e6"><view class="form-item data-v-2d2095e6"><text class="label data-v-2d2095e6">分类名称</text><input class="input data-v-2d2095e6" placeholder="请输入分类名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['formData']]]]]}}" value="{{formData.name}}" bindinput="__e"/></view><view class="form-item data-v-2d2095e6"><text class="label data-v-2d2095e6">排序值（越大越靠前）</text><input class="input data-v-2d2095e6" type="number" placeholder="请输入排序值" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','sortOrder','$event',[]],['formData']]]]]}}" value="{{formData.sortOrder}}" bindinput="__e"/></view></view><view class="dialog-footer data-v-2d2095e6"><button data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="cancel-btn data-v-2d2095e6" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['handleSubmit',['$event']]]]]}}" class="confirm-btn data-v-2d2095e6" bindtap="__e">确定</button></view></view></view></block><view class="admin-nav data-v-2d2095e6"><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/product/list']]]]]}}" class="nav-item data-v-2d2095e6" bindtap="__e"><text class="data-v-2d2095e6">商品</text></view><view class="nav-item active data-v-2d2095e6"><text class="data-v-2d2095e6">分类</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/order/list']]]]]}}" class="nav-item data-v-2d2095e6" bindtap="__e"><text class="data-v-2d2095e6">订单</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/user/list']]]]]}}" class="nav-item data-v-2d2095e6" bindtap="__e"><text class="data-v-2d2095e6">用户</text></view></view></view>