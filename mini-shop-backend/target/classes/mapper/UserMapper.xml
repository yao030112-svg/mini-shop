<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minishop.mapper.UserMapper">

    <!-- 结果映射 -->
    <resultMap id="UserResultMap" type="com.minishop.entity.User">
        <id property="id" column="id"/>
        <result property="openid" column="openid"/>
        <result property="nickname" column="nickname"/>
        <result property="avatarUrl" column="avatar_url"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="role" column="role"/>
        <result property="password" column="password"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id, openid, nickname, avatar_url, phone, status, role, password, create_time, update_time, deleted
    </sql>

    <!-- 根据ID查询用户 -->
    <select id="findById" resultMap="UserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id} AND deleted = 0
    </select>

    <!-- 根据openid查询用户 -->
    <select id="findByOpenid" resultMap="UserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE openid = #{openid} AND deleted = 0
    </select>

    <!-- 新增用户 -->
    <insert id="insert" parameterType="com.minishop.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (openid, nickname, avatar_url, phone, status, role, password)
        VALUES (#{openid}, #{nickname}, #{avatarUrl}, #{phone}, #{status}, #{role}, #{password})
    </insert>

    <!-- 更新用户信息 -->
    <update id="update" parameterType="com.minishop.entity.User">
        UPDATE user
        <set>
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="avatarUrl != null">avatar_url = #{avatarUrl},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="status != null">status = #{status},</if>
            <if test="role != null">role = #{role},</if>
            <if test="password != null">password = #{password},</if>
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

    <!-- 更新用户状态 -->
    <update id="updateStatus">
        UPDATE user
        SET status = #{status}
        WHERE id = #{id} AND deleted = 0
    </update>

    <!-- 根据昵称和角色查找用户（用于管理员登录） -->
    <select id="findByNicknameAndRole" resultMap="UserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE nickname = #{nickname} AND role = #{role} AND deleted = 0
    </select>

    <!-- 查询所有用户列表 -->
    <select id="selectList" resultMap="UserResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE deleted = 0
        ORDER BY create_time DESC
    </select>

    <!-- 统计所有用户数量 -->
    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM user WHERE deleted = 0
    </select>

    <!-- 统计指定时间范围内的新增用户数量 -->
    <select id="countByDateRange" resultType="int">
        SELECT COUNT(*)
        FROM user
        WHERE deleted = 0
          AND create_time BETWEEN #{startTime} AND #{endTime}
    </select>

</mapper>
