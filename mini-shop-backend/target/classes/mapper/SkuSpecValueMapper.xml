<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minishop.mapper.SkuSpecValueMapper">

    <!-- 结果映射 -->
    <resultMap id="SkuSpecValueResultMap" type="com.minishop.entity.SkuSpecValue">
        <id property="id" column="id"/>
        <result property="skuId" column="sku_id"/>
        <result property="specValueId" column="spec_value_id"/>
    </resultMap>

    <!-- 根据SKU ID查询关联的规格值 -->
    <select id="selectBySkuId" resultMap="SkuSpecValueResultMap">
        SELECT id, sku_id, spec_value_id
        FROM sku_spec_value
        WHERE sku_id = #{skuId}
    </select>

    <!-- 新增SKU与规格值关联 -->
    <insert id="insert" parameterType="com.minishop.entity.SkuSpecValue" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sku_spec_value (sku_id, spec_value_id)
        VALUES (#{skuId}, #{specValueId})
    </insert>

    <!-- 根据SKU ID删除关联 -->
    <delete id="deleteBySkuId">
        DELETE FROM sku_spec_value
        WHERE sku_id = #{skuId}
    </delete>

    <!-- 根据商品ID删除所有SKU的规格值关联 -->
    <delete id="deleteByProductId">
        DELETE FROM sku_spec_value
        WHERE sku_id IN (
            SELECT id FROM sku WHERE product_id = #{productId}
        )
    </delete>

</mapper>
