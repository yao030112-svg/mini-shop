<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minishop.mapper.SpecValueMapper">

    <!-- 结果映射 -->
    <resultMap id="SpecValueResultMap" type="com.minishop.entity.SpecValue">
        <id property="id" column="id"/>
        <result property="specId" column="spec_id"/>
        <result property="value" column="value"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>

    <!-- 根据规格维度ID查询规格值列表 -->
    <select id="selectBySpecId" resultMap="SpecValueResultMap">
        SELECT id, spec_id, value, sort_order
        FROM spec_value
        WHERE spec_id = #{specId}
        ORDER BY sort_order ASC
    </select>

    <!-- 新增规格值 -->
    <insert id="insert" parameterType="com.minishop.entity.SpecValue" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO spec_value (spec_id, value, sort_order)
        VALUES (#{specId}, #{value}, #{sortOrder})
    </insert>

    <!-- 根据规格维度ID删除所有规格值 -->
    <delete id="deleteBySpecId">
        DELETE FROM spec_value
        WHERE spec_id = #{specId}
    </delete>

    <!-- 根据商品ID删除所有规格值 -->
    <delete id="deleteByProductId">
        DELETE FROM spec_value
        WHERE spec_id IN (
            SELECT id FROM product_spec WHERE product_id = #{productId}
        )
    </delete>

</mapper>
