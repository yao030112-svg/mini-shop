<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minishop.mapper.CategoryMapper">

    <!-- 结果映射 -->
    <resultMap id="CategoryResultMap" type="com.minishop.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id, name, icon, sort_order, create_time, update_time, deleted
    </sql>

    <!-- 查询所有分类列表（按 sort_order 降序） -->
    <select id="selectList" resultMap="CategoryResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM category
        WHERE deleted = 0
        ORDER BY sort_order DESC
    </select>

    <!-- 根据ID查询分类 -->
    <select id="findById" resultMap="CategoryResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM category
        WHERE id = #{id} AND deleted = 0
    </select>

    <!-- 新增分类 -->
    <insert id="insert" parameterType="com.minishop.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, icon, sort_order)
        VALUES (#{name}, #{icon}, #{sortOrder})
    </insert>

    <!-- 更新分类 -->
    <update id="update" parameterType="com.minishop.entity.Category">
        UPDATE category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

    <!-- 逻辑删除分类 -->
    <update id="deleteById">
        UPDATE category
        SET deleted = 1
        WHERE id = #{id} AND deleted = 0
    </update>

    <!-- 统计分类下商品数量 -->
    <select id="countProductsByCategoryId" resultType="int">
        SELECT COUNT(*)
        FROM product
        WHERE category_id = #{categoryId} AND deleted = 0
    </select>

</mapper>
