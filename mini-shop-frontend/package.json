    "@dcloudio/uni-mp-weixin": "2.0.2-3081220230817001",
    "@dcloudio/uni-stat": "2.0.2-3081220230817001",
    "core-js": "3.8.3",
    "flyio": "0.6.2",
    "vue": "2.6.14",
    "vuex": "3.6.2"
  },
  "devDependencies": {
    "@dcloudio/types": "3.3.2",
    "@dcloudio/uni-automator": "2.0.2-3081220230817001",
