<view class="admin-banner data-v-4e6d6990"><view class="page-header data-v-4e6d6990"><text class="page-title data-v-4e6d6990">轮播图管理</text><button data-event-opts="{{[['tap',[['showAddDialog',['$event']]]]]}}" class="add-btn data-v-4e6d6990" bindtap="__e">添加轮播图</button></view><view class="banner-list data-v-4e6d6990"><block wx:for="{{bannerList}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="banner-item data-v-4e6d6990"><view class="banner-image-wrapper data-v-4e6d6990"><image class="banner-image data-v-4e6d6990" src="{{item.imageUrl}}" mode="aspectFill"></image></view><view class="banner-info data-v-4e6d6990"><text class="banner-title data-v-4e6d6990">{{"排序: "+(item.sortOrder||0)}}</text><text class="{{['banner-status','data-v-4e6d6990',item.status===1?'status-enabled':'status-disabled']}}">{{''+(item.status===1?'启用':'禁用')+''}}</text><block wx:if="{{item.linkUrl}}"><text class="banner-link data-v-4e6d6990">{{"链接: "+item.linkUrl}}</text></block></view><view class="banner-actions data-v-4e6d6990"><button data-event-opts="{{[['tap',[['handleToggleStatus',['$0'],[[['bannerList','id',item.id]]]]]]]}}" class="action-btn toggle-btn data-v-4e6d6990" bindtap="__e">{{''+(item.status===1?'禁用':'启用')+''}}</button><button data-event-opts="{{[['tap',[['showEditDialog',['$0'],[[['bannerList','id',item.id]]]]]]]}}" class="action-btn edit-btn data-v-4e6d6990" bindtap="__e">编辑</button><button data-event-opts="{{[['tap',[['handleDelete',['$0'],[[['bannerList','id',item.id]]]]]]]}}" class="action-btn del-btn data-v-4e6d6990" bindtap="__e">删除</button></view></view></block><block wx:if="{{$root.g0}}"><view class="empty data-v-4e6d6990"><text class="data-v-4e6d6990">暂无轮播图</text></view></block></view><block wx:if="{{dialogVisible}}"><view data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="dialog-mask data-v-4e6d6990" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="dialog data-v-4e6d6990" catchtap="__e"><text class="dialog-title data-v-4e6d6990">{{isEdit?'编辑轮播图':'添加轮播图'}}</text><view class="dialog-body data-v-4e6d6990"><view class="form-item data-v-4e6d6990"><text class="label data-v-4e6d6990">图片URL</text><input class="input data-v-4e6d6990" placeholder="请输入图片URL" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','imageUrl','$event',[]],['formData']]]]]}}" value="{{formData.imageUrl}}" bindinput="__e"/></view><view class="form-item data-v-4e6d6990"><text class="label data-v-4e6d6990">跳转链接（可选）</text><input class="input data-v-4e6d6990" placeholder="请输入跳转链接" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','linkUrl','$event',[]],['formData']]]]]}}" value="{{formData.linkUrl}}" bindinput="__e"/></view><view class="form-item data-v-4e6d6990"><text class="label data-v-4e6d6990">排序值</text><input class="input data-v-4e6d6990" type="number" placeholder="请输入排序值" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','sortOrder','$event',[]],['formData']]]]]}}" value="{{formData.sortOrder}}" bindinput="__e"/></view><view class="form-item data-v-4e6d6990"><text class="label data-v-4e6d6990">状态</text><view class="radio-group data-v-4e6d6990"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['radio-item','data-v-4e6d6990',(formData.status===1)?'active':'']}}" bindtap="__e"><text class="data-v-4e6d6990">启用</text></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['radio-item','data-v-4e6d6990',(formData.status===0)?'active':'']}}" bindtap="__e"><text class="data-v-4e6d6990">禁用</text></view></view></view></view><view class="dialog-footer data-v-4e6d6990"><button data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="cancel-btn data-v-4e6d6990" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['handleSubmit',['$event']]]]]}}" class="confirm-btn data-v-4e6d6990" bindtap="__e">确定</button></view></view></view></block><view class="admin-nav data-v-4e6d6990"><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/product/list']]]]]}}" class="nav-item data-v-4e6d6990" bindtap="__e"><text class="data-v-4e6d6990">商品</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/category/list']]]]]}}" class="nav-item data-v-4e6d6990" bindtap="__e"><text class="data-v-4e6d6990">分类</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/order/list']]]]]}}" class="nav-item data-v-4e6d6990" bindtap="__e"><text class="data-v-4e6d6990">订单</text></view><view data-event-opts="{{[['tap',[['navigateTo',['/pages/admin/user/list']]]]]}}" class="nav-item data-v-4e6d6990" bindtap="__e"><text class="data-v-4e6d6990">用户</text></view><view class="nav-item active data-v-4e6d6990"><text class="data-v-4e6d6990">轮播图</text></view></view></view>