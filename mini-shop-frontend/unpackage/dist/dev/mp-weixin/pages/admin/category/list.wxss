/* 商品列表 */
.product-list.data-v-2d2095e6 {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}
.product-item.data-v-2d2095e6 {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}
.product-item.data-v-2d2095e6:last-child {
  margin-bottom: 0;
}
.product-image.data-v-2d2095e6 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}
.product-info.data-v-2d2095e6 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.product-name.data-v-2d2095e6 {
  font-size: 26rpx;
  color: #333;
