<view class="admin-category data-v-2d2095e6"><view class="page-header data-v-2d2095e6"><text class="page-title data-v-2d2095e6">分类管理</text><button data-event-opts="{{[['tap',[['showAddDialog',['$event']]]]]}}" class="add-btn data-v-2d2095e6" bindtap="__e">添加分类</button></view><view class="category-list data-v-2d2095e6"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="category-wrapper data-v-2d2095e6"><view class="category-item data-v-2d2095e6"><view data-event-opts="{{[['tap',[['toggleProducts',['$0'],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="category-info data-v-2d2095e6" bindtap="__e"><text class="category-name data-v-2d2095e6">{{item.$orig.name}}</text><text class="category-sort data-v-2d2095e6">{{"排序: "+(item.$orig.sortOrder||0)}}</text><text class="expand-hint data-v-2d2095e6">{{expandedCategoryId===item.$orig.id?'点击收起':'点击查看商品'}}</text></view><view class="category-actions data-v-2d2095e6"><button data-event-opts="{{[['tap',[['handleSortUp',['$0',index],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="action-btn sort-btn data-v-2d2095e6" bindtap="__e">↑</button><button data-event-opts="{{[['tap',[['handleSortDown',['$0',index],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="action-btn sort-btn data-v-2d2095e6" bindtap="__e">↓</button><button data-event-opts="{{[['tap',[['showEditDialog',['$0'],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="action-btn edit-btn data-v-2d2095e6" bindtap="__e">编辑</button><button data-event-opts="{{[['tap',[['handleDelete',['$0'],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="action-btn del-btn data-v-2d2095e6" bindtap="__e">删除</button></view></view><block wx:if="{{expandedCategoryId===item.$orig.id}}"><view class="product-list data-v-2d2095e6"><block wx:for="{{currentProducts}}" wx:for-item="product" wx:for-index="__i0__" wx:key="id"><view class="product-item data-v-2d2095e6"><image class="product-image data-v-2d2095e6" src="{{product.mainImage}}" mode="aspectFill"></image><view class="product-info data-v-2d2095e6"><text class="product-name data-v-2d2095e6">{{product.name}}</text><text class="product-price data-v-2d2095e6">{{"￥"+product.minPrice}}</text><text class="{{['product-status','data-v-2d2095e6',product.status===1?'status-on':'status-off']}}">{{''+(product.status===1?'上架':'下架')+''}}</text></view></view></block><block wx:if="{{item.g0===0}}"><view class="empty-product data-v-2d2095e6"><text class="data-v-2d2095e6">该分类下暂无商品</text></view></block></view></block></view></block><block wx:if="{{$root.g1}}"><view class="empty data-v-2d2095e6"><text class="data-v-2d2095e6">暂无分类</text></view></block></view><block wx:if="{{dialogVisible}}"><view data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="dialog-mask data-v-2d2095e6" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="dialog data-v-2d2095e6" catchtap="__e"><text class="dialog-title data-v-2d2095e6">{{isEdit?'编辑分类':'添加分类'}}</text><view class="dialog-body data-v-2d2095e6"><view class="form-item data-v-2d2095e6"><text class="label data-v-2d2095e6">分类名称</text><input class="input data-v-2d2095e6" placeholder="请输入分类名称" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['formData']]]]]}}" value="{{formData.name}}" bindinput="__e"/></view><view class="form-item data-v-2d2095e6"><text class="label data-v-2d2095e6">排序值（越大越靠前）</text><input class="input data-v-2d2095e6" type="number" placeholder="请输入排序值" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','sortOrder','$event',[]],['formData']]]]]}}" value="{{formData.sortOrder}}" bindinput="__e"/></view></view><view class="dialog-footer data-v-2d2095e6"><button data-event-opts="{{[['tap',[['closeDialog',['$event']]]]]}}" class="cancel-btn data-v-2d2095e6" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['handleSubmit',['$event']]]]]}}" class="confirm-btn data-v-2d2095e6" bindtap="__e"