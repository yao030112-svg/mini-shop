<view class="user-page"><view data-event-opts="{{[['tap',[['handleUserClick',['$event']]]]]}}" class="user-header" bindtap="__e"><image class="user-header__avatar" src="{{userInfo?userInfo.avatarUrl:'/static/images/default-avatar.png'}}" mode="aspectFill"></image><view class="user-header__info"><text class="user-header__name">{{userInfo?userInfo.nickname:'点击登录'}}</text><block wx:if="{{!userInfo}}"><text class="user-header__desc">登录后显示微信头像和昵称</text></block></view></view><view class="menu-section"><view data-event-opts="{{[['tap',[['goAbout',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-item__text">关于我们</text></view></view><block wx:if="{{userInfo}}"><view class="logout-section"><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="logout-btn" bindtap="__e"><text class="logout-btn__text">退出登录</text></view></view></block></view>