.user-page.data-v-137d5072 {
  min-height: 100vh;
  background-color: #f8f8f8;
}
/* 用户信息区 */
.user-header.data-v-137d5072 {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #ff6600, #ff8533);
}
.user-header__avatar.data-v-137d5072 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 32rpx;
}
.user-header__info.data-v-137d5072 {
  flex: 1;
}
.user-header__name.data-v-137d5072 {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  display: block;
}
.user-header__desc.data-v-137d5072 {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}
/* 订单区域 */
