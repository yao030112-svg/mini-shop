.address-list.data-v-5d053e52 {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 120rpx;
}
.list-content.data-v-5d053e52 {
  padding: 16rpx;
}
/* 地址卡片 */
.address-card.data-v-5d053e52 {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.address-card__content.data-v-5d053e52 {
  padding: 24rpx;
}
.address-card__top.data-v-5d053e52 {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.address-card__name.data-v-5d053e52 {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-right: 24rpx;
}
.address-card__phone.data-v-5d053e52 {
  font-size: 28rpx;
  color: #666666;
}
.address-card__tag.data-v-5d053e52 {
  margin-left: 16rpx;
  background-color: rgba(255, 102, 0, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.address-card__tag-text.data-v-5d053e52 {
  font-size: 20rpx;
  color: #ff6600;
}
.address-card__detail.data-v-5d053e52 {
  padding-right: 24rpx;
}
.address-card__detail-text.data-v-5d053e52 {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}
.address-card__actions.data-v-5d053e52 {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}
.address-card__action.data-v-5d053e52 {
  padding: 8rpx 20rpx;
  margin-left: 16rpx;
}
.address-card__action--danger.data-v-5d053e52 {
  /* danger style handled by text */
}
.address-card__action-text.data-v-5d053e52 {
  font-size: 24rpx;
  color: #666666;
}
.address-card__action-text--danger.data-v-5d053e52 {
  color: #ee0a24;
}
/* 空状态 */
.empty.data-v-5d053e52 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}
.empty__text.data-v-5d053e52 {
  font-size: 28rpx;
  color: #999999;
}
.empty__sub.data-v-5d053e52 {
  font-size: 24rpx;
  color: #cccccc;
  margin-top: 12rpx;
}
/* 底部按钮 */
.bottom-bar.data-v-5d053e52 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.add-btn.data-v-5d053e52 {
  background-color: #ff6600;
  border-radius: 999rpx;
  padding: 24rpx;
  text-align: center;
}
.add-btn__text.data-v-5d053e52 {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}
