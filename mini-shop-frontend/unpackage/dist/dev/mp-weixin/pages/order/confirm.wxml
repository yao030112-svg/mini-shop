<view class="order-confirm data-v-400081d6"><view data-event-opts="{{[['tap',[['chooseAddress',['$event']]]]]}}" class="address-section data-v-400081d6" bindtap="__e"><block wx:if="{{address}}"><view class="address-card data-v-400081d6"><view class="address-card__info data-v-400081d6"><view class="address-card__user data-v-400081d6"><text class="address-card__name data-v-400081d6">{{address.receiverName}}</text><text class="address-card__phone data-v-400081d6">{{address.phone}}</text></view><view class="address-card__detail data-v-400081d6"><text class="data-v-400081d6">{{address.province+address.city+address.district+address.detail}}</text></view></view><view class="address-card__arrow data-v-400081d6"><text class="iconfont data-v-400081d6">›</text></view></view></block><block wx:else><view class="address-empty data-v-400081d6"><text class="address-empty__text data-v-400081d6">请添加收货地址</text><text class="address-empty__arrow data-v-400081d6">›</text></view></block></view><view class="goods-section data-v-400081d6"><block wx:for="{{goodsList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="goods-item data-v-400081d6"><image class="goods-item__image data-v-400081d6" src="{{item.image}}" mode="aspectFill"></image><view class="goods-item__info data-v-400081d6"><text class="goods-item__name data-v-400081d6">{{item.productName}}</text><block wx:if="{{item.skuSpecDesc}}"><text class="goods-item__spec data-v-400081d6">{{item.skuSpecDesc}}</text></block><view class="goods-item__bottom data-v-400081d6"><text class="goods-item__price data-v-400081d6">{{"¥"+(item.skuPrice||item.price)}}</text><text class="goods-item__qty data-v-400081d6">{{"x"+item.quantity}}</text></view></view></view></block></view><view class="summary-section data-v-400081d6"><view class="summary-row data-v-400081d6"><text class="summary-row__label data-v-400081d6">商品金额</text><text class="summary-row__value data-v-400081d6">{{"¥"+totalAmount}}</text></view><view class="summary-row data-v-400081d6"><text class="summary-row__label data-v-400081d6">运费</text><text class="summary-row__value data-v-400081d6">免运费</text></view></view><view class="bottom-placeholder data-v-400081d6"></view><view class="bottom-bar data-v-400081d6"><view class="bottom-bar__total data-v-400081d6"><text class="bottom-bar__label data-v-400081d6">合计：</text><text class="bottom-bar__price data-v-400081d6">{{"¥"+totalAmount}}</text></view><view data-event-opts="{{[['tap',[['handleSubmit',['$event']]]]]}}" class="bottom-bar__btn data-v-400081d6" bindtap="__e"><text class="bottom-bar__btn-text data-v-400081d6">提交订单</text></view></view></view>