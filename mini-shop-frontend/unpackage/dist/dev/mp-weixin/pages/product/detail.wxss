/* 圆角 */
.product-detail.data-v-0e9671aa {
  min-height: 100vh;
  background-color: #f8f8f8;
}
/* 商品图片轮播 */
.product-swiper.data-v-0e9671aa {
  width: 100%;
  height: 750rpx;
}
.product-swiper__image.data-v-0e9671aa {
  width: 100%;
  height: 100%;
}
/* 商品基本信息 */
.product-info.data-v-0e9671aa {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.product-info__price.data-v-0e9671aa {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.product-info__stock.data-v-0e9671aa {
  font-size: 24rpx;
  color: #999999;
}
.product-info__name.data-v-0e9671aa {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 10rpx;
}
.product-info__desc.data-v-0e9671aa {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}
/* SKU 规格选择器 */
.spec-selector.data-v-0e9671aa {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.spec-selector__title.data-v-0e9671aa {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}
.spec-group.data-v-0e9671aa {
  margin-bottom: 24rpx;
}
.spec-group.data-v-0e9671aa:last-child {
  margin-bottom: 0;
}
.spec-group__name.data-v-0e9671aa {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}
.spec-group__values.data-v-0e9671aa {
  display: flex;
  flex-wrap: wrap;
}
.spec-value.data-v-0e9671aa {
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  background-color: #f5f5f5;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
}
.spec-value--active.data-v-0e9671aa {
  background-color: rgba(255, 102, 0, 0.1);
  border-color: #ff6600;
}
.spec-value--active .spec-value__text.data-v-0e9671aa {
  color: #ff6600;
}
.spec-value--disabled.data-v-0e9671aa {
  opacity: 0.4;
  background-color: #f5f5f5;
}
.spec-value--disabled .spec-value__text.data-v-0e9671aa {
  color: #999999;
  text-decoration: line-through;
}
.spec-value__text.data-v-0e9671aa {
  font-size: 24rpx;
  color: #333333;
}
/* 底部占位 */
.bottom-placeholder.data-v-0e9671aa {
  height: 120rpx;
}
/* 底部固定栏 */
.bottom-bar.data-v-0e9671aa {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}
.bottom-bar__btn.data-v-0e9671aa {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  margin-right: 16rpx;
}
.bottom-bar__btn.data-v-0e9671aa:last-child {
  margin-right: 0;
}
.bottom-bar__btn--cart.data-v-0e9671aa {
  background-color: #ff6600;
}
.bottom-bar__btn--buy.data-v-0e9671aa {
  background-color: #ff4444;
}
.bottom-bar__btn--disabled.data-v-0e9671aa {
  background-color: #999999;
}
.bottom-bar__btn-text.data-v-0e9671aa {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}
